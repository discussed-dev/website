---
const installs = [
  {
    label: 'Chrome',
    icon: '/store-icons/chrome-web-store.png',
    href: 'https://chromewebstore.google.com/detail/discussed/hhomlcmeodcgipjpjfiogjokckhibkhm',
  },
  {
    label: 'Firefox',
    icon: '/store-icons/firefox.svg',
    href: 'https://addons.mozilla.org/en-US/firefox/addon/discussed/',
  },
  {
    label: 'Edge',
    icon: '/store-icons/edge.svg',
    href: 'https://github.com/discussed-dev/extension/releases/download/v0.1.0/discussed-0.1.0-chrome.zip',
    download: true,
  },
];
---
<section class="py-8 sm:py-12">
  <div class="shell">
    <div class="grid gap-10 lg:grid-cols-[0.8fr_minmax(32rem,1.5fr)] lg:items-start lg:gap-10">
      <div>
        <p class="text-[0.75rem] font-semibold tracking-[0.12em] uppercase text-[color:var(--text-muted)]">
          Free & Open Source
        </p>
        <h1 class="mt-6 font-[family-name:var(--font-serif)] text-[clamp(2.8rem,6vw,4.5rem)] font-normal leading-[1.05] tracking-[-0.02em] text-[color:var(--text)]" style="max-width:42rem">
          Every page has a conversation. Find it.
        </h1>
        <p class="mt-6 text-[1.1rem] leading-[1.7] text-[color:var(--text-muted)]" style="max-width:32rem">
          Discussed surfaces threads from Hacker News, Reddit, and Lobsters for whatever you're reading. No account needed.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          {installs.map((item) => (
            <a
              href={item.href}
              {...(item.download ? { download: true } : {})}
              class:list={[
                'inline-flex items-center px-5 py-2.5 rounded-lg text-[0.9rem] font-medium no-underline transition-all',
                item.primary
                  ? 'bg-[color:var(--accent)] text-white hover:opacity-90'
                  : 'border border-[color:var(--border)] text-[color:var(--text)] hover:border-[color:var(--text-muted)]',
              ]}
            >
              <img src={item.icon} alt="" width="40" height="40" class="size-10 object-contain" />
              {item.label}
            </a>
          ))}
        </div>
        <p class="mt-3 text-[0.8rem] text-[color:var(--text-faint)]">Edge store listing coming soon. Download the zip to install manually.</p>
        <div class="mt-4 flex gap-6 text-[0.85rem]">
          <a href="https://github.com/discussed-dev/extension" class="text-[color:var(--text-muted)] no-underline border-b border-[color:var(--border)] pb-px transition-colors hover:text-[color:var(--text)]">Source on GitHub</a>
          <a href="/privacy" class="text-[color:var(--text-muted)] no-underline border-b border-[color:var(--border)] pb-px transition-colors hover:text-[color:var(--text)]">Privacy</a>
        </div>
      </div>

      <div class="lg:mt-10">
        <div class="overflow-hidden rounded-lg border border-[color:var(--border)]">
          <img
            src="/media/discussed-extension.gif"
            alt="Screen recording of the Discussed extension finding discussions and opening its popup"
            width="1080"
            height="761"
            loading="eager"
            decoding="async"
            class="h-auto w-full"
          />
        </div>
      </div>
    </div>
  </div>
</section>
