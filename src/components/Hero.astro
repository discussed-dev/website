---
const installs = [
  {
    action: 'Add to Chrome',
    store: 'Chrome Web Store',
    icon: '/store-icons/chrome-web-store.png',
    href: 'https://github.com/discussed-dev/extension/releases/download/v0.1.0/discussed-0.1.0-chrome.zip',
  },
  {
    action: 'Add to Firefox',
    store: 'Firefox Add-ons',
    icon: '/store-icons/firefox-addons.ico',
    href: 'https://github.com/discussed-dev/extension/releases/download/v0.1.0/discussed-0.1.0-firefox.zip',
  },
  {
    action: 'Add to Edge',
    store: 'Edge Add-ons',
    icon: '/store-icons/edge-addons.ico',
    href: 'https://github.com/discussed-dev/extension/releases/download/v0.1.0/discussed-0.1.0-chrome.zip',
  },
];
---
<section class="pb-12 pt-10 sm:pb-16 sm:pt-14">
  <div class="site-shell">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,0.9fr)_minmax(24rem,1.1fr)] lg:items-start lg:gap-12">
      <div class="max-w-2xl">
        <span class="eyebrow">Discussed browser extension</span>

        <h1 class="mt-6 max-w-3xl text-[clamp(2.6rem,5.4vw,4.4rem)] font-semibold leading-[0.95] tracking-[-0.05em] text-[color:var(--page-ink)]">
          See what people are saying about any page.
        </h1>

        <p class="mt-4 text-[1rem] leading-7 text-[color:var(--page-ink-soft)] sm:text-[1.06rem]">
          HN, Reddit, and Lobsters in one place.
        </p>

        <div class="mt-8 grid gap-3 sm:grid-cols-3">
          {installs.map((install) => (
            <a href={install.href} class="install-card" download>
              <div class="flex items-center gap-3">
                <span class="install-icon-wrap">
                  <img src={install.icon} alt="" class="install-icon" width="32" height="32" loading="eager" decoding="async" />
                </span>
                <span class="install-copy">
                  <strong>{install.action}</strong>
                  <span>{install.store}</span>
                </span>
              </div>
              <em>v0.1.0</em>
            </a>
          ))}
        </div>

        <div class="mt-4 flex flex-wrap items-center gap-3 text-sm text-[color:var(--page-ink-muted)]">
          <a href="https://github.com/discussed-dev/extension" class="button-secondary">GitHub</a>
          <a href="/privacy" class="button-ghost">Privacy</a>
        </div>
      </div>

      <div class="surface-soft rounded-[0.75rem] p-2 sm:p-2.5 lg:mt-[3.25rem]">
        <p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-[color:var(--page-ink-muted)]">In action</p>
        <div class="mt-3 overflow-hidden rounded-[0.6rem] border border-[var(--page-line)] bg-[color:var(--page-panel-strong)]">
          <video
            class="motion-safe-media h-auto w-full"
            width="1080"
            height="761"
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            poster="/media/discussed-extension-poster.png"
            aria-label="Screen recording of the Discussed extension finding discussions and opening its popup"
          >
            <source src="/media/discussed-extension.webm" type="video/webm" />
            <source src="/media/discussed-extension.mp4" type="video/mp4" />
          </video>
          <img
            src="/media/discussed-extension-poster.png"
            alt="Screen recording preview of the Discussed extension finding discussions and opening its popup"
            width="1080"
            height="761"
            class="motion-reduce-media h-auto w-full"
            loading="eager"
            decoding="async"
          />
        </div>
        <p class="px-1 pt-3 text-sm leading-7 text-[color:var(--page-ink-muted)]">
          Also available in 7 languages.
        </p>
      </div>
    </div>
  </div>
</section>
