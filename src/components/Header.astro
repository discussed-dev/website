---
---
<header class="pt-5 sm:pt-7">
  <div class="site-shell">
    <div class="flex items-center justify-between gap-4 rounded-[1.1rem] border border-[var(--page-line)] bg-[color:var(--page-panel-strong)] px-4 py-3 shadow-[var(--header-shadow)] sm:px-6">
      <a href="/" class="inline-flex items-center" aria-label="Discussed home">
        <img
          src="/brand/discussed-logo.svg"
          alt="Discussed"
          width="1024"
          height="512"
          loading="eager"
          decoding="sync"
          fetchpriority="high"
          class="h-[3.5rem] w-auto sm:h-[4.25rem]"
        />
      </a>

      <div class="flex flex-wrap items-center justify-end gap-1 text-sm text-[color:var(--page-ink-soft)] sm:gap-2">
        <a href="/privacy" class="header-link">Privacy</a>
        <a href="https://github.com/discussed-dev/extension" class="header-link">GitHub</a>
      </div>
    </div>
  </div>
</header>
