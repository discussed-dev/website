---
const steps = [
  {
    title: 'Browse normally',
    description: 'Discussed checks whether a page already has discussion around it.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3" />`,
  },
  {
    title: 'Open the popup',
    description: 'HN, Reddit, and Lobsters show up in one compact view.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133" />`,
  },
  {
    title: 'Summarize if needed',
    description: 'Use your own API key when the thread volume is too high.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25" />`,
  },
];
---
<section class="py-14 sm:py-18">
  <div class="site-shell">
    <div class="surface-soft rounded-[2rem] p-6 sm:p-8">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div class="max-w-xl">
          <span class="eyebrow">How it works</span>
          <h2 class="section-title mt-5 text-[color:var(--page-ink)]">Three short steps.</h2>
        </div>
        <p class="max-w-md text-sm leading-7 text-[color:var(--page-ink-soft)]">
          The extension is meant to be quick to open, quick to scan, and easy to trust.
        </p>
      </div>

      <div class="mt-8 grid gap-4 md:grid-cols-3">
        {steps.map((step) => (
          <article class="rounded-[1.5rem] border border-[var(--page-line)] bg-[color:var(--page-panel-strong)] p-5">
            <div class="inline-flex size-11 items-center justify-center rounded-full bg-[color:var(--page-highlight)] text-[color:var(--color-brand-orange-deep)]">
              <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" set:html={step.icon} />
            </div>
            <h3 class="mt-4 text-lg font-semibold tracking-[-0.03em] text-[color:var(--page-ink)]">{step.title}</h3>
            <p class="mt-2 text-sm leading-7 text-[color:var(--page-ink-soft)]">{step.description}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
