---
const steps = [
  {
    num: '01',
    title: 'Install and forget',
    description: 'A badge lights up when the page you\'re on has been discussed somewhere. Most pages don\'t, so most of the time you see nothing.',
  },
  {
    num: '02',
    title: 'Click when curious',
    description: 'A popup lists every thread across HN, Reddit, and Lobsters. Sorted by comments so the interesting ones float up.',
  },
  {
    num: '03',
    title: 'Summarize the noise',
    description: 'Too many threads? One click gets you an AI summary across all of them. Bring your own API key.',
  },
];
---
<section class="py-16 sm:py-20">
  <div class="shell">
    <h2 class="font-[family-name:var(--font-serif)] text-[2rem] font-normal text-[color:var(--text)]">
      Three steps, no setup
    </h2>
    <div class="mt-12 grid gap-10 sm:grid-cols-3">
      {steps.map((step) => (
        <div>
          <p class="font-mono text-[0.75rem] font-medium text-[color:var(--accent)]">{step.num}</p>
          <h3 class="mt-3 text-[1.05rem] font-semibold text-[color:var(--text)]">{step.title}</h3>
          <p class="mt-2 text-[0.9rem] leading-[1.65] text-[color:var(--text-muted)]">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
